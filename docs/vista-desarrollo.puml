@startuml vista-desarrollo-mmglowbeauty
' Reglas PlantUML 1.2026: no mezclar actor con component;
' no usar <<stereotipo>> en package con color; no usar \\n en nombres;
' definir relaciones al final del archivo.
!theme plain

skinparam packageStyle rectangle
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam arrowThickness 1.5
skinparam componentStyle rectangle

title Vista de Desarrollo - M and M Glow Beauty\n(Alineada con Contexto, Funcional, Logica y Despliegue)

legend right
  Controller REST
  DTO
  Service
  Repository
  Model
  Security
  Config
  Externo
endlegend

package "Actores - Vista de Contexto" #FAFAFA {
  [Cliente] as actorCliente
  [Empleada] as actorEmpleada
  [Administradora] as actorAdmin
}

package "Frontend - Vista de Despliegue externo" #F5F5F5 {
  component WebApp
}

package "App Server - Docker Render" #ECEFF1 {

  component API_ENTRY

  package "Configuracion transversal" #FFF3E0 {
    component SecurityConfig
    component CorsConfig
    component MongoConfig
    component SwaggerConfig
    component GlobalExceptionHandler
  }

  package "Autenticacion y Seguridad" #E0F7FA {
    component AuthController
    component AuthService
    component JwtUtil
    component JwtAuthenticationFilter as JwtAuthFilter
    component UserDetailsServiceImpl as UserDetailsService
    component AuthRequest
    component AuthResponse
  }

  package "Gestion Usuarios y Personal" #E8F5E9 {
    component UsuarioController
    component UsuarioService
    component UsuarioRepository
    component UsuarioRequest
    component Usuario as ModelUsuario
    component Cliente as ModelCliente
    component Empleada as ModelEmpleada
    component Administradora as ModelAdministradora
  }

  package "Gestion Citas Agenda Calificaciones" #E8F5E9 {
    component CitaController
    component CitaService
    component CitaRepository
    component CalificacionController
    component CalificacionService
    component CalificacionRepository
    component RecordatorioScheduler
    component RecordatorioRepository
    component CitaRequest
    component CitaResponse
    component CalificacionRequest
    component Cita as ModelCita
    component Calificacion as ModelCalificacion
    component Recordatorio as ModelRecordatorio
  }

  package "Gestion Servicios Promociones Anuncios" #E8F5E9 {
    component ServicioController
    component TipoServicioController
    component ComboController
    component PromocionController
    component AnuncioController
    component ServicioService
    component TipoServicioService
    component ComboService
    component PromocionService
    component AnuncioService
    component ServicioRepository
    component TipoServicioRepository
    component ComboRepository
    component PromocionRepository
    component AnuncioRepository
    component Servicio as ModelServicio
    component TipoServicio as ModelTipoServicio
    component Combo as ModelCombo
    component Promocion as ModelPromocion
    component Anuncio as ModelAnuncio
  }

  package "Gestion Inventario" #E8F5E9 {
    component InventarioController
    component InventarioService
    component ProductoRepository
    component ProductoResponse
    component Producto as ModelProducto
  }

  package "Pagos y Reportes" #E8F5E9 {
    component PagoController
    component ReporteController
    component PagoService
    component ReporteService
    component PagoRepository
    component Pago as ModelPago
  }

  package "Notificaciones y Comunicacion" #E8F5E9 {
    component NotificacionController
    component NotificacionService
    component NotificacionStrategy
    component EmailStrategy
    component WhatsAppStrategy
  }
}

cloud "Sistema de Notificaciones" as NOTIF_CLOUD #F5F5F5 {
  component "SMTP Gmail" as SMTP
  component "Twilio WhatsApp" as Twilio
}

database "MongoDB 7" as MONGO #F5F5F5

note right of MONGO
  Colecciones: usuarios, citas,
  servicios, productos, anuncios,
  pagos, recordatorios, calificaciones,
  promociones, combos, tipos_servicio
end note

SecurityConfig --> JwtAuthFilter
JwtAuthFilter --> JwtUtil
JwtAuthFilter --> UserDetailsService
UserDetailsService --> UsuarioRepository

AuthController --> AuthService
AuthService --> UsuarioRepository
AuthService --> JwtUtil

UsuarioController --> UsuarioService
UsuarioService --> UsuarioRepository
UsuarioRepository --> ModelUsuario
ModelUsuario <|-- ModelCliente
ModelUsuario <|-- ModelEmpleada
ModelUsuario <|-- ModelAdministradora

CitaController --> CitaService
CitaService --> CitaRepository
CitaService --> NotificacionStrategy
RecordatorioScheduler --> CitaRepository
RecordatorioScheduler --> NotificacionStrategy

InventarioController --> InventarioService
InventarioController --> ProductoResponse
InventarioService --> ProductoRepository
InventarioService --> NotificacionStrategy

NotificacionStrategy <|-- EmailStrategy
NotificacionStrategy <|-- WhatsAppStrategy
EmailStrategy --> SMTP
WhatsAppStrategy --> Twilio

actorCliente ..> NOTIF_CLOUD : Email WhatsApp

UsuarioRepository --> MONGO
CitaRepository --> MONGO
ProductoRepository --> MONGO
PagoRepository --> MONGO
ServicioRepository --> MONGO

MongoConfig ..> MONGO
GlobalExceptionHandler ..> API_ENTRY

actorCliente --> WebApp
actorEmpleada --> WebApp
actorAdmin --> WebApp
WebApp --> API_ENTRY

@enduml
