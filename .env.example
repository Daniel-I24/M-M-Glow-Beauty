# =============================================================================
# M&M Glow Beauty - Variables de entorno
# Copiar a .env (local) o configurar en Render / Docker
# =============================================================================

# --- Base de datos (local: Docker | produccion: MongoDB Atlas) ---
MONGO_URI=mongodb://localhost:27017/mmglowbeauty
# Produccion Atlas (ejemplo):
# MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/mmglowbeauty?retryWrites=true&w=majority

# --- JWT (OBLIGATORIO cambiar en produccion) ---
JWT_SECRET=genera-un-secreto-largo-aleatorio-minimo-32-caracteres

# --- Email (Gmail App Password) ---
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Twilio WhatsApp (opcional si notificacion.canal=WHATSAPP) ---
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=whatsapp:+1234567890

# --- Canal de notificacion: EMAIL o WHATSAPP ---
NOTIFICACION_CANAL=EMAIL

# --- CORS (frontend) ---
# Local Vite:
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Produccion (ejemplo Vercel):
# CORS_ALLOWED_ORIGINS=https://mmglowbeauty.vercel.app

# --- Almacenamiento de imagenes (opcional - Cloudinary o AWS S3) ---
STORAGE_PROVIDER=local
# Cloudinary:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# AWS S3 (alternativa):
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
# AWS_REGION=us-east-1

# --- Puerto (Render usa PORT automaticamente) ---
# SERVER_PORT=8080
